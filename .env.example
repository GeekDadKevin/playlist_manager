# Flask mode for local/dev startup.
FLASK_ENV=development
# Session/signing secret; change this for any shared or production deployment.
SECRET_KEY=change-me
# Browser UI and API port. The app is designed to stay on 3000.
APP_PORT=3000
# App data folder for settings, history DB, and generated playlist files.
DATA_DIR=/app/data

# ListenBrainz connection used by the import UI playlist chooser.
LISTENBRAINZ_API_BASE_URL=https://api.listenbrainz.org
# Your ListenBrainz username so the app can list Created For You and your own playlists.
LISTENBRAINZ_USERNAME=
# Optional ListenBrainz auth token if your requests need authentication.
LISTENBRAINZ_AUTH_TOKEN=

# Deezer fuzzy-match acceptance threshold (0-100).
DEEZER_MATCH_THRESHOLD=72
# Safety cap for how many tracks one sync run will process.
SYNC_MAX_TRACKS=100

# Navidrome URL used for links and status messaging in the UI.
NAVIDROME_BASE_URL=http://navidrome:4533
# Host folder that Navidrome watches for imported/exported playlists.
NAVIDROME_PLAYLIST_DIR=/absolute/path/on/your/docker-host/navidrome/playlists
# Prefix written into playlist entries; `..` gives `../Artist`.
NAVIDROME_M3U_PATH_PREFIX=..
# Host music root used for both existing-library checks and new Deezer downloads.
NAVIDROME_MUSIC_ROOT=/absolute/path/on/your/docker-host/music/root

# Deezer download settings for the live sync step.
DEEZER_ARL=
DEEZER_QUALITY=FLAC

# Docker Compose mounts the two host paths above into `/navidrome/playlist`
# and `/navidrome/root` inside the container for stable in-app paths.
