FLASK_ENV=development
SECRET_KEY=change-me
APP_PORT=3000
DATA_DIR=/app/data
UPLOAD_FOLDER=/app/data/uploads

# Optional: ListenBrainz playlist import
LISTENBRAINZ_API_BASE_URL=https://api.listenbrainz.org
LISTENBRAINZ_USERNAME=
LISTENBRAINZ_AUTH_TOKEN=
LISTENBRAINZ_PLAYLIST_TYPE=createdfor
LISTENBRAINZ_PLAYLIST_ID=
LISTENBRAINZ_JSPF_URL=

# Octo-Fiesta (required)
OCTO_FIESTA_BASE_URL=http://octo-fiesta:5274
OCTO_FIESTA_USERNAME=
OCTO_FIESTA_PASSWORD=

# Optional: token auth instead of password
# OCTO_FIESTA_TOKEN=
# OCTO_FIESTA_SALT=

# Optional overrides (defaults are shown)
# OCTO_FIESTA_HANDOFF_MODE=download
# OCTO_FIESTA_CLIENT_NAME=jspf-converter
# OCTO_FIESTA_API_VERSION=1.16.1
# OCTO_FIESTA_PROVIDER=deezer
# OCTO_FIESTA_MATCH_THRESHOLD=72

SYNC_MAX_TRACKS=100
NAVIDROME_BASE_URL=http://navidrome:4533
NAVIDROME_PLAYLISTS_DIR=/app/data/navidrome_playlists

# Docker Compose only: map this to the real host path Navidrome scans for playlist files.
# NAVIDROME_PLAYLISTS_DIR_HOST=/path/on/your/docker-host/navidrome/playlists
