# Flask mode for local/dev startup.
FLASK_ENV=development
# Session/signing secret; change this for any shared or production deployment.
SECRET_KEY=change-me
# Browser UI and API port. The app is designed to stay on 3000.
APP_PORT=3000
# App data folder for settings, history DB, and generated playlist files.
# Keep this repo-local for local testing; Docker Compose still maps this to /app/data in-container.
DATA_DIR=./data

# config.json is auto-applied inside Docker. Local start scripts use .env by default.
# Set PLAYLIST_MANAGER_USE_CONFIG_JSON=1 only if you explicitly want local runs to inherit config.json.

# ListenBrainz connection used by the import UI playlist chooser.
LISTENBRAINZ_API_BASE_URL=https://api.listenbrainz.org
# Your ListenBrainz username so the app can list Created For You and your own playlists.
LISTENBRAINZ_USERNAME=
# Optional ListenBrainz auth token if your requests need authentication.
LISTENBRAINZ_AUTH_TOKEN=

# Optional audio fingerprint fallback for severely broken files.
# Requires an AcoustID API key plus the fpcalc binary from Chromaprint.
ACOUSTID_API_KEY=
ACOUSTID_LOOKUP_TIMEOUT=20
ACOUSTID_SCORE_THRESHOLD=0.9
ACOUSTID_FINGERPRINT_LENGTH=120
FPCALC_BIN=

# Deezer fuzzy-match acceptance threshold (0-100).
DEEZER_MATCH_THRESHOLD=72
# Safety cap for how many tracks one sync run will process.
SYNC_MAX_TRACKS=100
# Download worker threads (1 = sequential).
DOWNLOAD_THREADS=1

# Navidrome URL used for links and status messaging in the UI.
NAVIDROME_BASE_URL=http://navidrome:4533
# Host folder that Navidrome watches for imported/exported playlists.
NAVIDROME_PLAYLIST_DIR=/absolute/path/on/your/docker-host/navidrome/playlists
# Prefix written into playlist entries; `..` gives `../Artist`.
NAVIDROME_M3U_PATH_PREFIX=..
# Host music root used for existing-library checks, Deezer downloads, and any
# SoundCloud file you explicitly choose during low-confidence review.
NAVIDROME_MUSIC_ROOT=/absolute/path/on/your/docker-host/music/root

# Live sync settings. SoundCloud/YouTube are offered only during low-confidence review.
DEEZER_ARL=
DEEZER_QUALITY=FLAC
SOUNDCLOUD_FALLBACK=1
YOUTUBE_FALLBACK=0
SOUNDCLOUD_MATCH_THRESHOLD=72
YOUTUBE_MATCH_THRESHOLD=72
# Raise these if Docker/SoundCloud lookups hit transient SSL handshake timeouts.
SOUNDCLOUD_REQUEST_TIMEOUT=25
SOUNDCLOUD_REQUEST_RETRIES=3
SOUNDCLOUD_FORCE_IPV4=1
# Raise these if Docker/YouTube lookups hit transient SSL handshake timeouts.
YOUTUBE_REQUEST_TIMEOUT=25
YOUTUBE_REQUEST_RETRIES=3
YOUTUBE_FORCE_IPV4=1

# Docker Compose mounts the two host paths above into `/navidrome/playlist`
# and `/navidrome/root` inside the container for stable in-app paths.
